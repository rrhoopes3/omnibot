# OmniBot primary model path
OMNIBOT_PROVIDER=xai
OMNIBOT_MODEL=grok-4.3
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# Optional local fallback: LM Studio
OMNIBOT_LMSTUDIO_MODEL=local-model
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=

# Optional local fallback: Ollama
OMNIBOT_OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Optional search providers
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Tool safety toggles
# Set to false to block subprocess shell/Python execution from OmniBot.
OMNIBOT_ENABLE_SHELL=true
OMNIBOT_ENABLE_PYTHON=true
